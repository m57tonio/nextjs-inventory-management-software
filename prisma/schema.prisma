generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int       @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String    @unique
  password    String
  phoneNumber String?
  image       String?
  role        String    @default("user")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes are avoided — users own audit trails and uploaded assets.
  deletedAt   DateTime?

  @@index([deletedAt])
}

// Lookup table for valid staff roles (admin, manager, cashier, user …).
// The Users create/edit form populates the Role dropdown from this table,
// not from hardcoded strings, so new roles can be added without code changes.
model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String
  logo      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes avoided because products will reference this brand.
  deletedAt DateTime?

  products Product[]

  @@index([deletedAt])
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  logo      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes avoided because products will reference this category.
  deletedAt DateTime?

  products Product[]

  @@index([deletedAt])
}

model Warehouse {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  phoneNumber String?
  country     String?
  city        String?
  zipCode     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes are intentionally avoided because warehouses will be
  // referenced by stock, sales, and purchases records.
  deletedAt   DateTime?

  stocks ProductStock[]

  @@index([deletedAt])
}

model Supplier {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  phoneNumber String?
  country     String?
  city        String?
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes are avoided because suppliers will be referenced by purchases.
  deletedAt   DateTime?

  stocks ProductStock[]

  @@index([deletedAt])
}

model Customer {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  phoneNumber String?
  dateOfBirth DateTime?
  country     String?
  city        String?
  // TEXT column — addresses can be multi-line and exceed VARCHAR(191).
  address     String?   @db.Text
  // Marks the protected walk-in / POS default customer ("direct-customer").
  // This record must never be soft-deleted; it is created by the seed script.
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes avoided because customers are referenced by sales/quotations.
  deletedAt   DateTime?

  @@index([deletedAt])
  @@index([isDefault])
}

model Product {
  id                 Int       @id @default(autoincrement())
  name               String
  // Unique SKU / barcode code — enforced at DB level.
  code               String    @unique
  price              Decimal   @db.Decimal(12, 2)
  categoryId         Int
  brandId            Int
  productUnit        String
  stockAlert         Int?
  orderTax           Decimal?  @db.Decimal(5, 2)
  // "Exclusive" = tax added on top of price; "Inclusive" = tax built into price.
  taxType            String    @default("Exclusive")
  quantityLimitation Int?
  notes              String?   @db.Text
  // JSON array of upload paths, e.g. ["/uploads/products/img1.jpg"].
  // First element is used as the list thumbnail.
  images             String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-delete is blocked if the product is referenced by purchases/sales.
  deletedAt          DateTime?

  category Category      @relation(fields: [categoryId], references: [id])
  brand    Brand         @relation(fields: [brandId], references: [id])
  stocks   ProductStock[]

  @@index([deletedAt])
  @@index([categoryId])
  @@index([brandId])
}

// Per-warehouse stock ledger.  Stock is NEVER a column on Product — it lives
// here so each warehouse maintains its own quantity independently.
model ProductStock {
  id          Int      @id @default(autoincrement())
  productId   Int
  warehouseId Int
  supplierId  Int?
  quantity    Int      @default(0)
  // Received | Pending | Ordered
  status      String   @default("Received")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  supplier  Supplier? @relation(fields: [supplierId], references: [id])

  @@index([productId])
  @@index([warehouseId])
  @@index([supplierId])
}
