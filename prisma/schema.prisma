generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int       @id @default(autoincrement())
  firstName   String
  lastName    String
  email       String    @unique
  password    String
  phoneNumber String?
  image       String?
  role        String    @default("user")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes are avoided — users own audit trails and uploaded assets.
  deletedAt   DateTime?

  @@index([deletedAt])
}

// Lookup table for valid staff roles (admin, manager, cashier, user …).
// The Users create/edit form populates the Role dropdown from this table,
// not from hardcoded strings, so new roles can be added without code changes.
model Role {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Brand {
  id        Int       @id @default(autoincrement())
  name      String
  logo      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes avoided because products will reference this brand.
  deletedAt DateTime?

  products Product[]

  @@index([deletedAt])
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String
  logo      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes avoided because products will reference this category.
  deletedAt DateTime?

  products Product[]

  @@index([deletedAt])
}

model Warehouse {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  phoneNumber String?
  country     String?
  city        String?
  zipCode     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes are intentionally avoided because warehouses will be
  // referenced by stock, sales, and purchases records.
  deletedAt   DateTime?

  stocks      ProductStock[]
  adjustments Adjustment[]
  purchases   Purchase[]

  @@index([deletedAt])
}

model Supplier {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  phoneNumber String?
  country     String?
  city        String?
  address     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes are avoided because suppliers will be referenced by purchases.
  deletedAt   DateTime?

  stocks    ProductStock[]
  purchases Purchase[]

  @@index([deletedAt])
}

model Customer {
  id          Int       @id @default(autoincrement())
  name        String
  email       String?
  phoneNumber String?
  dateOfBirth DateTime?
  country     String?
  city        String?
  // TEXT column — addresses can be multi-line and exceed VARCHAR(191).
  address     String?   @db.Text
  // Marks the protected walk-in / POS default customer ("direct-customer").
  // This record must never be soft-deleted; it is created by the seed script.
  isDefault   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-deletes avoided because customers are referenced by sales/quotations.
  deletedAt   DateTime?

  @@index([deletedAt])
  @@index([isDefault])
}

// Measurement units shown in the Product Unit dropdown.
// Managed via the /units CRUD page (not yet built).
// Product.productUnit stores the name as a string — no FK — so renaming a unit
// doesn't silently change historical product records.
model Unit {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([deletedAt])
}

model Product {
  id                 Int       @id @default(autoincrement())
  name               String
  // Unique SKU / barcode code — enforced at DB level.
  code               String    @unique
  price              Decimal   @db.Decimal(12, 2)
  categoryId         Int
  brandId            Int
  productUnit        String
  stockAlert         Int?
  orderTax           Decimal?  @db.Decimal(5, 2)
  // "Exclusive" = tax added on top of price; "Inclusive" = tax built into price.
  taxType            String    @default("Exclusive")
  quantityLimitation Int?
  notes              String?   @db.Text
  // JSON array of upload paths, e.g. ["/uploads/products/img1.jpg"].
  // First element is used as the list thumbnail.
  images             String?   @db.Text
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  // Soft-delete: null = active, non-null = deleted.
  // Hard-delete is blocked if the product is referenced by purchases/sales.
  deletedAt          DateTime?

  category        Category         @relation(fields: [categoryId], references: [id])
  brand           Brand            @relation(fields: [brandId], references: [id])
  stocks          ProductStock[]
  adjustmentItems AdjustmentItem[]
  purchaseItems   PurchaseItem[]

  @@index([deletedAt])
  @@index([categoryId])
  @@index([brandId])
}

// Per-warehouse stock ledger.  Stock is NEVER a column on Product — it lives
// here so each warehouse maintains its own quantity independently.
model ProductStock {
  id          Int      @id @default(autoincrement())
  productId   Int
  warehouseId Int
  supplierId  Int?
  quantity    Int      @default(0)
  // Received | Pending | Ordered
  status      String   @default("Received")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  supplier  Supplier? @relation(fields: [supplierId], references: [id])

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@index([supplierId])
}

// ── Inventory Adjustments ─────────────────────────────────────────────────────
// An Adjustment is a manual stock correction (up or down) for a single
// warehouse.  It is a multi-line document: one header + N items.
model Adjustment {
  id          Int       @id @default(autoincrement())
  // Human-readable reference generated at save time, e.g. "ADJ_0001".
  reference   String    @unique
  warehouseId Int
  date        DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  warehouse Warehouse        @relation(fields: [warehouseId], references: [id])
  items     AdjustmentItem[]

  @@index([deletedAt])
  @@index([warehouseId])
}

model AdjustmentItem {
  id           Int      @id @default(autoincrement())
  adjustmentId Int
  productId    Int
  quantity     Int
  // "Addition" increments ProductStock; "Subtraction" decrements it.
  type         String
  createdAt    DateTime @default(now())

  adjustment Adjustment @relation(fields: [adjustmentId], references: [id])
  product    Product    @relation(fields: [productId], references: [id])

  @@index([adjustmentId])
  @@index([productId])
}

// ── Purchases ─────────────────────────────────────────────────────────────────
// A Purchase is a stock-inbound document: supplier → warehouse.
// When status = "Received", each line increments ProductStock for the
// chosen warehouse via the stock service inside a $transaction.
// Pending/Ordered purchases do NOT move stock until status changes to Received.
model Purchase {
  id            Int       @id @default(autoincrement())
  // Human-readable reference, e.g. "PU_0001". Generated after insert so the
  // autoincrement id is available; temporarily stored as TEMP_<ts>_<rand>.
  reference     String    @unique
  supplierId    Int
  warehouseId   Int
  date          DateTime
  // Pending | Ordered | Received
  status        String    @default("Received")
  // Order-level tax as a percentage applied to the sum of line subtotals.
  orderTax      Decimal   @default(0) @db.Decimal(5, 2)
  // Order-level flat discount in base currency.
  discount      Decimal   @default(0) @db.Decimal(12, 2)
  // Flat shipping cost added to the total.
  shipping      Decimal   @default(0) @db.Decimal(12, 2)
  // Server-computed from line subtotals + order tax/discount/shipping.
  grandTotal    Decimal   @db.Decimal(14, 2)
  // Cash | Card | Cheque | Bank Transfer
  paymentType   String    @default("Cash")
  // Paid | Unpaid | Partial
  paymentStatus String    @default("Paid")
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  supplier  Supplier       @relation(fields: [supplierId], references: [id])
  warehouse Warehouse      @relation(fields: [warehouseId], references: [id])
  items     PurchaseItem[]

  @@index([deletedAt])
  @@index([supplierId])
  @@index([warehouseId])
  @@index([status])
}

// One line of a Purchase document.  Subtotal is server-computed and stored so
// the view/PDF never has to re-run the pricing logic from raw inputs.
model PurchaseItem {
  id           Int     @id @default(autoincrement())
  purchaseId   Int
  productId    Int
  // Unit cost for this specific purchase (may differ from Product.price).
  netUnitCost  Decimal @db.Decimal(12, 2)
  quantity     Int
  // Fixed | Percentage
  discountType String  @default("Fixed")
  discount     Decimal @default(0) @db.Decimal(12, 2)
  // Inclusive | Exclusive
  taxType      String  @default("Exclusive")
  // Per-line tax rate as a percentage.
  orderTax     Decimal @default(0) @db.Decimal(5, 2)
  // Server-computed: unitCost×qty adjusted for discount and tax.
  subtotal     Decimal @db.Decimal(14, 2)
  // Unit label for this purchase line (may differ from product's default unit).
  purchaseUnit String
  createdAt    DateTime @default(now())

  purchase Purchase @relation(fields: [purchaseId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@index([purchaseId])
  @@index([productId])
}
